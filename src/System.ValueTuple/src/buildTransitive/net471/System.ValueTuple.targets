<Project>
  <!-- Use the reference from the package instead of the targeting pack, avoiding conflict -->
  <ItemGroup>
    <!-- We cannot have more than one primary reference, since others might resolve to the lower versioned framework assembly and the conflict will persist.-->
    <Reference Remove="System.ValueTuple" />
    <!-- Private="false" prevents the assembly from being copied to the output directory.
         SpecificVersion="true" prevents a warning from ResolveAssemblyReference about a mismatch in reference versions
         that will be ignored at runtime by .NETFramework's assembly unification.-->
    <Reference Include="$([MSBuild]::NormalizePath($(MSBuildThisFileDirectory), '..', '..', 'lib', 'net47', 'System.ValueTuple.dll'))" Private="false" SpecificVersion="true" />
  </ItemGroup>

</Project>
